{
  "name": "san-cordova",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "vite",
    "dev:multiplayer-server": "PORT=4173 node server.mjs",
    "build": "tsc -b && vite build && node tools/check-bundle.mjs && node tools/precompress.mjs",
    "bake": "tsx tools/bake/index.ts",
    "heroku-postbuild": "npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "character:build": "node tools/character/build.mjs",
    "character:validate": "node tools/character/validate.mjs",
    "foliage:build": "node tools/foliage/build.mjs",
    "foliage:validate": "node tools/foliage/validate.mjs",
    "npc:build": "node tools/npc/build.mjs",
    "npc:validate": "node tools/npc/validate.mjs",
    "vehicle:build": "node tools/vehicle/build.mjs",
    "vehicle:validate": "node tools/vehicle/validate.mjs",
    "map:build": "tsx tools/mapgen/index.ts",
    "map:png": "tsx tools/mapgen/render-png.ts"
  },
  "dependencies": {
    "geoip-country": "^5.0.202607180103",
    "pg": "^8.22.0",
    "three": "^0.178.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@napi-rs/canvas": "^1.0.2",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.178.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "tsx": "^4.23.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
